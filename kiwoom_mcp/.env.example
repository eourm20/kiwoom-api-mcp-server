# ===================================================
# [필수 변경] 개인 인증 정보 - 반드시 본인 값으로 교체
# ===================================================
KIWOOM_APP_KEY=your_app_key
KIWOOM_APP_SECRET=your_app_secret
KIWOOM_ACCOUNT_NO=your_account_no

# ===================================================
# [선택 변경] Claude Desktop config에서 설정 권장
# ===================================================
# 실전: https://api.kiwoom.com / 모의투자: https://mockapi.kiwoom.com
KIWOOM_BASE_URL=https://api.kiwoom.com
# 주문/정정/취소 허용 여부 (true로 변경 시 실거래 가능)
KIWOOM_ALLOW_TRADE_EXECUTION=false

# ===================================================
# [수정 불필요] 기본값 유지
# ===================================================
KIWOOM_TOKEN_PATH=/oauth2/token
KIWOOM_ACCOUNT_PATH=/api/dostk/acnt
KIWOOM_WS_BASE_URL=wss://api.kiwoom.com:10000
KIWOOM_REALTIME_PATH=/api/dostk/websocket
KIWOOM_DEPOSITS_API_ID=kt00015
KIWOOM_TRADES_API_ID=kt00015
KIWOOM_ACCOUNT_BALANCE_API_ID=kt00001
KIWOOM_DMST_STEX_TP=%
KIWOOM_GDS_TP=1
KIWOOM_CRNC_CD=KRW
KIWOOM_CATALOG_PATH=docs/KIWOOM_REST_API_CATALOG.md
KIWOOM_API_PDF_PATH=docs/키움 REST API 문서.pdf

# For Claude Desktop stdio usage, keep this as `stdio`.
# Change to `http` only when you intentionally run streamable HTTP.
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_HTTP_PATH=/mcp
